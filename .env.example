NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=mendez_barbershop

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=changeme-min-32-chars-please-replace
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme-min-32-chars-please-replace-too
JWT_REFRESH_EXPIRES_IN=7d

# Used by `npm run seed`. Creates super admin, barbershop, and tenant admin.
SUPER_ADMIN_EMAIL=admin@tusistema.com
SUPER_ADMIN_PASSWORD=changeme
SUPER_ADMIN_NAME=Super Admin

ADMIN_TENANT_CODE=mendez
# ADMIN_TENANT_NAME defaults to the code capitalized ("Mendez")
# ADMIN_TENANT_NAME=Barbería Méndez
ADMIN_EMAIL=admin@mendez.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin
