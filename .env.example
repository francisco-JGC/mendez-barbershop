NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=mendez_barbershop

# Used to verify the Host header subdomain against the resolved tenant.
# e.g. if BASE_DOMAIN=tusistema.com, then mendez.tusistema.com -> subdomain "mendez"
BASE_DOMAIN=tusistema.com

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=changeme-min-32-chars-please-replace
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme-min-32-chars-please-replace-too
JWT_REFRESH_EXPIRES_IN=7d
