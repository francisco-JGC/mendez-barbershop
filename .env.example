NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=mendez_barbershop

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=changeme-min-32-chars-please-replace
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme-min-32-chars-please-replace-too
JWT_REFRESH_EXPIRES_IN=7d

# Optional: used by `npm run seed:super-admin` (falls back to CLI args
# `npm run seed:super-admin -- <email> <password> [name]` if not set).
# SUPER_ADMIN_EMAIL=admin@tusistema.com
# SUPER_ADMIN_PASSWORD=changeme
# SUPER_ADMIN_NAME=Super Admin

# Optional: used by `npm run seed:admin` (falls back to CLI args
# `npm run seed:admin -- <tenantCode> <email> <password> [name]` if not set).
# The barbershop with this code must already exist (created via
# POST /api/tenants as super_admin).
# ADMIN_TENANT_CODE=mendez
# ADMIN_EMAIL=admin@mendez.com
# ADMIN_PASSWORD=changeme
# ADMIN_NAME=Admin
